rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Global Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getProject(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }

    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    function isCollaborator(projectId) {
      return isSignedIn() && exists(/databases/$(database)/documents/projectMembers/$(projectId + "_" + request.auth.uid));
    }

    function canAccessProject(projectId) {
      return isOwner(getProject(projectId)) || isCollaborator(projectId);
    }

    // --- Entity Validation Blueprints ---

    function isValidProject(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() <= 200 &&
             data.ownerId is string &&
             (data.createdAt == request.time || data.createdAt is string);
    }

    function isValidProjectMember(data) {
       return data.keys().hasAll(['projectId', 'email', 'role', 'invitedAt']) &&
              isValidId(data.projectId) &&
              data.email is string &&
              data.role is string &&
              (data.invitedAt == request.time || data.invitedAt is string);
    }

    function isValidScene(data) {
      return data.keys().hasAll(['projectId', 'ownerId', 'number', 'location', 'intExt', 'dayNight', 'order']) &&
             isValidId(data.projectId) &&
             data.number is string &&
             data.location is string &&
             data.order is int;
    }

    function isValidStoryboard(data) {
       return data.keys().hasAll(['sceneId', 'projectId', 'ownerId', 'imageUrl', 'order']) &&
              isValidId(data.sceneId) &&
              isValidId(data.projectId) &&
              data.imageUrl is string &&
              data.order is int;
    }

    function isValidScriptVersion(data) {
      return data.keys().hasAll(['projectId', 'ownerId', 'fileName', 'uploadDate', 'version', 'status']) &&
             isValidId(data.projectId) &&
             data.fileName is string &&
             data.version is number;
    }

    // --- Collection Rules ---

    match /projects/{projectId} {
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming());
      // List rules must align with query filters
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (isOwner(existing()) || isCollaborator(projectId));
      allow update: if isSignedIn() && (isOwner(existing()) || isCollaborator(projectId)) && 
                    incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    match /projectMembers/{memberId} {
      allow create: if isSignedIn() && canAccessProject(incoming().projectId) && isValidProjectMember(incoming());
      allow read: if isSignedIn() && (
        isOwner(getProject(resource.data.projectId)) || 
        resource.data.userId == request.auth.uid || 
        resource.data.email == request.auth.token.email
      );
      allow update: if isSignedIn() && (
        isOwner(getProject(existing().projectId)) ||
        existing().email == request.auth.token.email
      );
      allow delete: if isSignedIn() && isOwner(getProject(existing().projectId));
      // Allow listing members
      allow list: if isSignedIn();
    }

    match /scenes/{sceneId} {
      allow create: if isSignedIn() && isValidScene(incoming()) && canAccessProject(incoming().projectId);
      allow list: if isSignedIn() && canAccessProject(resource.data.projectId);
      allow get: if isSignedIn() && canAccessProject(existing().projectId);
      allow update: if isSignedIn() && canAccessProject(existing().projectId) && 
                    isValidScene(incoming()) &&
                    incoming().projectId == existing().projectId;
      allow delete: if isSignedIn() && canAccessProject(existing().projectId);
    }

    match /scriptVersions/{versionId} {
      allow create: if isSignedIn() && isValidScriptVersion(incoming()) && canAccessProject(incoming().projectId);
      allow list: if isSignedIn();
      allow get: if isSignedIn() && canAccessProject(existing().projectId);
      allow update: if isSignedIn() && canAccessProject(existing().projectId) &&
                    incoming().projectId == existing().projectId;
      allow delete: if isSignedIn() && canAccessProject(existing().projectId);
    }

    match /storyboards/{frameId} {
      allow create: if isSignedIn() && isValidStoryboard(incoming()) && canAccessProject(incoming().projectId);
      allow list: if isSignedIn();
      allow get: if isSignedIn() && canAccessProject(existing().projectId);
      allow update: if isSignedIn() && canAccessProject(existing().projectId) && isValidStoryboard(incoming()) &&
                    incoming().projectId == existing().projectId;
      allow delete: if isSignedIn() && canAccessProject(existing().projectId);
    }

    match /stripboard/{stripId} {
      allow create: if isSignedIn() && canAccessProject(incoming().projectId);
      allow list: if isSignedIn();
      allow get: if isSignedIn() && canAccessProject(existing().projectId);
      allow update: if isSignedIn() && canAccessProject(existing().projectId);
      allow delete: if isSignedIn() && canAccessProject(existing().projectId);
    }
  }
}
